{
  "name": "rhea-promise",
  "version": "3.0.3",
  "description": "A Promisified layer over rhea AMQP client",
  "license": "Apache-2.0",
  "main": "./dist/lib/index.js",
  "types": "./typings/lib/index.d.ts",
  "dependencies": {
    "debug": "^4.4.3",
    "rhea": "^3.0.5",
    "tslib": "^2.8.1"
  },
  "keywords": [
    "amqp",
    "rhea",
    "promise",
    "amqp-10",
    "messaging"
  ],
  "files": [
    "dist/lib/",
    "lib/",
    "typings/lib/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/debug": "^4.1.13",
    "@types/node": "^20.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "lint": "eslint .",
    "tsc": "tsc",
    "prebuild": "rimraf dist && rimraf typings",
    "build": "npm run check-format && npm run lint && npm run tsc && npm run extract-api",
    "check-format": "prettier --list-different \"lib/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\" \"*.{js,json}\"",
    "extract-api": "api-extractor run --local",
    "format": "prettier --write \"lib/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\" \"*.{js,json}\"",
    "test": "npm run build && vitest run",
    "prepack": "npm ci && npm run build"
  },
  "homepage": "https://github.com/amqp/rhea-promise",
  "repository": {
    "type": "git",
    "url": "https://github.com/amqp/rhea-promise.git"
  },
  "bugs": {
    "url": "http://github.com/amqp/rhea-promise/issues"
  }
}
