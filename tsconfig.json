{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "preserveConstEnums": true,
    "sourceMap": true,
    "newLine": "LF",
    "target": "es2015",
    "importHelpers": true,
    "types": ["node"],
    "noImplicitReturns": true,
    "outDir": "dist",
    "allowJs": false,
    "noUnusedLocals": true,
    "strict": true,
    "declaration": true,
    "declarationDir": "./typings",
    "declarationMap": true,
    "useUnknownInCatchVariables": false
  },
  "compileOnSave": true,
  "exclude": ["node_modules", "typings/**"],
  "include": ["./lib/**/*.ts", "./examples/**/*.ts", "./test/**/*.ts"]
}
